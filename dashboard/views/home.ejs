<!DOCTYPE html>
<html lang="en">

<head>
  <title>GD Macro Sharing</title>
  <link rel="icon" href="/assets/logo.ico" type="image/x-icon">

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">

  <meta name="title" content="GD Macro Sharing">
  <meta name="description" content="Browse and share geometry dash macros">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://gd.584924.xyz/">
  <meta property="og:title" content="GD Macro Sharing">
  <meta property="og:description" content="Browse and share geometry dash macros">
  <meta property="og:image" content="https://gd.584924.xyz/assets/logo.ico">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://gd.584924.xyz/">
  <meta property="twitter:title" content="GD Macro Sharing">
  <meta property="twitter:description" content="Browse and share geometry dash macros">
  <meta property="twitter:image" content="https://gd.584924.xyz/assets/logo.ico">

  <meta name="theme-color" content="#1f53f0">
</head>

<body>
  <%- include('partials/navbar') %>

  <section class="intro">
    <h1>Welcome to GD Macro Sharing</h1>
    <p>Here you can upload your Geometry Dash macros or browse macros other users have created</p>
  </section>

  <section class="leaderboard-section">
    <h2>Macro Upload Leaderboard</h2>

    <% if (leaderboard.length === 0) { %>
      <p>No macros uploaded yet!</p>
    <% } else { %>
      <table style="width:100%; text-align:left; border-collapse:collapse;">
        <% leaderboard.forEach((user, index) => { %>
          <tr style="<%= user.isMe ? 'background: rgba(88,101,242,0.1);' : '' %> border-bottom: 1px solid #333;">
            <td style="padding:10px;">#<%= index + 1 %></td>
            <td style="padding:10px;">
              <img src="<%= user.avatar || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png' %>"
                   style="width:30px; border-radius:50%; vertical-align:middle; margin-right:10px;">
              <strong><%= user.username %></strong>
              <% if (user.isMe) { %>
                <span style="color:#5865F2;">(You)</span>
              <% } %>
            </td>
            <td style="padding:10px; text-align:right;"><%= user.count %> macros</td>
          </tr>
        <% }) %>
      </table>
    <% } %>

    <p style="font-size:0.8em; color:#888; margin-top:15px;">
      Total macros uploaded in this server: <%= totalMacros %>
    </p>
  </section>
</body>

</html>